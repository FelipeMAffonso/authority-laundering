# Authority-laundering pilot, API key template.
# Copy this file to config/.env (or the project-root .env) and fill in.
# All three keys are required to replicate the full nine-model matrix.
# Running a subset of providers is supported by editing the MODELS list
# in run_focused_pilot.py and run_grounded_study.py.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Optional: OpenRouter key for open-weight model replication
# (Llama, Qwen, Gemma builds). The pilot does not require this key.
# OPENROUTER_API_KEY=sk-or-...
